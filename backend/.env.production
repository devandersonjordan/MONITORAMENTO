APP_NAME="Solar SaaS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://agilizesolar.online
APP_TIMEZONE=America/Maceio

FRONTEND_URL=https://agilizesolar.online

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ==========================================
# BANCO DE DADOS
# ==========================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=solar_saas
DB_USERNAME=solar
DB_PASSWORD=TROCAR_POR_SENHA_FORTE_AQUI

# ==========================================
# SESSAO E CACHE
# ==========================================
SESSION_DRIVER=redis
SESSION_LIFETIME=120
BROADCAST_CONNECTION=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis
CACHE_PREFIX=solar_saas_

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=TROCAR_POR_SENHA_REDIS_AQUI
REDIS_PORT=6379

# ==========================================
# EMAIL (SMTP Producao)
# ==========================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=noreply@agilizesolar.online
MAIL_PASSWORD=TROCAR_SENHA_EMAIL
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="noreply@agilizesolar.online"
MAIL_FROM_NAME="${APP_NAME}"

# ==========================================
# SANCTUM
# ==========================================
SANCTUM_STATEFUL_DOMAINS=agilizesolar.online

# ==========================================
# CLAUDE AI (Anthropic)
# ==========================================
CLAUDE_API_KEY=sk-ant-api03-XXXXXXXXXXXX
CLAUDE_MODEL=claude-sonnet-4-20250514

# ==========================================
# WHATSAPP (Evolution API)
# ==========================================
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_FROM_NUMBER=

# ==========================================
# BACKUP
# ==========================================
BACKUP_NOTIFICATION_EMAIL=andersonjorda@gmail.com
BACKUP_ARCHIVE_PASSWORD=TROCAR_SENHA_BACKUP

# ==========================================
# SWAGGER
# ==========================================
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_UI_DOC_EXPANSION=none
